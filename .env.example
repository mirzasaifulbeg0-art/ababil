# ---------------------------------------------------------------------------
# ABABIL — Environment variables TEMPLATE
# Copy this file to ".env" and fill in the real values.
# NEVER commit the real ".env" file (it is gitignored).
# ---------------------------------------------------------------------------

# --- Database (PostgreSQL) -------------------------------------------------
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# Local example (after we install Postgres in setup):
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/ababil?schema=public"

# --- NextAuth / Auth.js ----------------------------------------------------
# Generate a secret with:  npx auth secret   (or)  openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-string"
# The full URL of the site. In local dev keep it as below.
NEXTAUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# --- Cloudinary (image & PDF storage) --------------------------------------
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
# Public cloud name is safe to expose to the browser for image URLs.
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""

# --- Razorpay (payments — fill in later, test mode first) ------------------
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
NEXT_PUBLIC_RAZORPAY_KEY_ID=""

# --- Business contact details (used on the site) ---------------------------
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_WHATSAPP_NUMBER="91XXXXXXXXXX"
NEXT_PUBLIC_CONTACT_PHONE="+91XXXXXXXXXX"
NEXT_PUBLIC_CONTACT_EMAIL="hello@ababil.example"
