# ---------------------------------------------------------------------------
# ABABIL — Production / Vercel environment variables (TEMPLATE)
# Set these in the Vercel dashboard → Project → Settings → Environment Variables.
# Do NOT commit real values. This template lists what the deployed app needs.
# ---------------------------------------------------------------------------

# --- Database (HOSTED PostgreSQL — NOT localhost) --------------------------
# Vercel runs in the cloud and cannot reach a local database.
# Use a hosted provider: Neon, Supabase, or Vercel Postgres.
# Neon/Supabase usually require SSL — keep ?sslmode=require if provided.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# --- NextAuth / Auth.js ----------------------------------------------------
# Generate with:  npx auth secret   (or)  openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-string"
# Must match your deployed URL exactly, e.g. https://ababil.vercel.app
NEXTAUTH_URL="https://YOUR-APP.vercel.app"
AUTH_TRUST_HOST="true"

# --- Cloudinary (REQUIRED in production for uploads) -----------------------
# Vercel's filesystem is read-only, so the local /public/uploads fallback does
# NOT work when deployed. Uploads only persist when Cloudinary is configured.
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""

# --- Seed admin (used once by `npm run db:seed`) ---------------------------
# IMPORTANT: set a STRONG password before seeding a public deployment.
# If unset, the seed falls back to a weak public default — do not ship that.
SEED_ADMIN_EMAIL="you@yourdomain.com"
SEED_ADMIN_PASSWORD="use-a-strong-unique-password"

# --- Razorpay (payments — optional until you enable checkout) --------------
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
NEXT_PUBLIC_RAZORPAY_KEY_ID=""

# --- Business contact details ----------------------------------------------
NEXT_PUBLIC_SITE_URL="https://YOUR-APP.vercel.app"
NEXT_PUBLIC_WHATSAPP_NUMBER="91XXXXXXXXXX"
NEXT_PUBLIC_CONTACT_PHONE="+91XXXXXXXXXX"
NEXT_PUBLIC_CONTACT_EMAIL="hello@ababil.example"
