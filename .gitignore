# ---------------------------------------------------------------------------
# ABABIL — Git ignore rules
# ---------------------------------------------------------------------------

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*

# next.js
/.next/
/out/
/build
next-env.d.ts

# production
/dist

# testing
/coverage

# environment variables — NEVER commit real secrets
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
# (the template ".env.example" is intentionally NOT ignored)

# prisma
/prisma/*.db
/prisma/*.db-journal

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# editor / OS
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
Thumbs.db

# vercel
.vercel

# typescript
*.tsbuildinfo

# local uploads (dev only — real files live on Cloudinary)
/public/uploads/*
!/public/uploads/.gitkeep
